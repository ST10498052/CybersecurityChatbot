<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="700" Width="900"
        Background="#1a1a2e" WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="750">

    <Window.Resources>
        <!-- Button style -->
        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderBrush" Value="#00d4ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#16213e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="CyberInput" TargetType="TextBox">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#00d4ff"/>
            <Setter Property="CaretBrush" Value="#00d4ff"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header/logo -->
            <RowDefinition Height="Auto"/>
            <!-- Name panel -->
            <RowDefinition Height="*"/>
            <!-- Chat area -->
            <RowDefinition Height="Auto"/>
            <!-- Input area -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="#0f3460" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="🛡  CYBERSECURITY AWARENESS BOT"
                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                           Foreground="#00d4ff" HorizontalAlignment="Center"/>
                <TextBlock Text="Protecting South African Citizens Online"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#7ecfff" HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── NAME ENTRY PANEL ── -->
        <Border x:Name="NamePanel" Grid.Row="1" Background="#16213e"
                CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Enter your name: " Foreground="#7ecfff"
                           FontFamily="Consolas" FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="NameInput" Style="{StaticResource CyberInput}"
                         Width="200" Margin="8,0"
                         KeyDown="NameInput_KeyDown"/>
                <Button Content="START CHAT" Style="{StaticResource CyberButton}"
                        Click="StartChat_Click"/>
            </StackPanel>
        </Border>

        <!-- ── CHAT DISPLAY ── -->
        <Border Grid.Row="2" Background="#16213e" CornerRadius="8"
                BorderBrush="#0f3460" BorderThickness="1" Margin="0,0,0,10">
            <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto"
                          Padding="8">
                <RichTextBox x:Name="ChatBox"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             Foreground="#e0e0e0"
                             VerticalScrollBarVisibility="Disabled"
                             Padding="8"/>
            </ScrollViewer>
        </Border>

        <!-- ── INPUT AREA ── -->
        <Grid Grid.Row="3" x:Name="InputArea" IsEnabled="False" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" x:Name="MessageInput"
                     Style="{StaticResource CyberInput}"
                     Margin="0,0,8,0"
                     KeyDown="MessageInput_KeyDown"
                     ToolTip="Type your message and press Enter or click Send"/>

            <Button Grid.Column="1" Content="SEND" Margin="0,0,8,0"
                    Style="{StaticResource CyberButton}"
                    Click="Send_Click"/>

            <Button Grid.Column="2" Content="QUIT"
                    Style="{StaticResource CyberButton}"
                    Background="#3d0000" BorderBrush="#ff4444"
                    Click="Quit_Click"/>
        </Grid>

        <!-- ── STATUS BAR ── -->
        <TextBlock x:Name="StatusBar" Grid.Row="4"
                   FontFamily="Consolas" FontSize="11"
                   Foreground="#555577"
                   Text="© The Independent Institute of Education (Pty) Ltd 2026"/>
    </Grid>
</Window>